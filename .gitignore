# Build artifacts
/bin/
/dist/
/genai-otel-bridge
/harness
*.exe
*.test
*.out

# Generated license/SBOM artifacts (release-time: baked into the image at /licenses/ and
# attached to the GitHub Release — never committed; they churn on every dependency bump).
# SBOMs land in /dist/sbom/, already covered by /dist/ above.
/THIRD_PARTY_NOTICES.md

# Pinned CI tooling (installed by `make tools` / `make tools-e2e`)
/.tools/

# Go
/vendor/
go.work
go.work.sum

# Secrets / local config (never commit credentials or per-env config)
.env
*.env
config.local.*
*.local.yaml
*.secret.*
# the real banned-term list (see scripts/forbidden-words.local.example)
scripts/forbidden-words.local

# Scratch: specs, plans, brainstorming drafts — persist on disk, never enter git history
docs/superpowers/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# gcx dashboard snapshot PNGs (scratch)
/snapshots/

# Zensical docs-site build output
/site/
