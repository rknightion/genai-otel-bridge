# Snyk (https://snyk.io) policy file.
#
# Records the disposition of every Snyk finding triaged on 2026-06-28 across all sources
# (Open Source / Code / IaC). Open Source was clean. Every entry below is a confirmed
# false-positive or an intentional, accepted design decision — not an unreviewed mute.
# See the triage commit message for the full per-finding assessment.
version: v1.25.0

exclude:
  global:
    # Third-party Terraform module CACHE — the gitignored `terraform init` download
    # (deploy/ecs/terraform/.gitignore: .terraform/). The open-egress (SNYK-CC-TF-72),
    # DynamoDB PITR (SNYK-CC-TF-125), KMS-rotation (SNYK-CC-TF-14) and ContainerInsights
    # (SNYK-CC-TF-128) hits here are the UPSTREAM modules' own source + examples, not how
    # this repo configures them. Our own main.tf enables PITR + SSE and owns its egress
    # rules. We never own or ship vendored module internals, so they are not scanned.
    - deploy/ecs/terraform/.terraform/**
    # Build-time code generators — `package main` under gen/, run only by `make generate`;
    # never compiled into the shipped binary. The path-traversal (CWE-23) hits take
    # Makefile-controlled args with safe in-repo default paths; no untrusted input.
    - internal/config/gen/**
    - internal/docs/gen/**
    # Build-time Grafana dashboard generator (sys.argv output path, safe default). Not shipped.
    - deploy/grafana/self-obs/gen_dashboard.py
    # Test-only httptest fake servers — Snyk's go/XSS/test rule fires on request data echoed
    # back inside test fixtures that are never shipped and never serve untrusted clients.
    - internal/app/recorder_test.go
    - internal/source/portkey/logs_collect_test.go
    # ECS HTTP-helper file (the sink of the go/Ssrf dataflow). resolveECSIdentity reads the trusted,
    # ECS-injected link-local task-metadata URL; healthCheckCode probes our OWN /healthz via a
    # loopback URL derived from the operator's -health-addr flag (localHealthURL forces 127.0.0.1).
    # Neither takes untrusted input. main.go itself stays scanned — only this helper is excluded.
    - cmd/genai-otel-bridge/ecs.go

ignore:
  # ─── First-party: intentional, accepted design ──────────────────────────────────────────────
  SNYK-CC-TF-73:
    - '*':
        reason: >-
          Intentional, documented default-egress allow-list (HTTPS/443 + DNS/53 to 0.0.0.0/0)
          for an outbound-only poller that must reach public OTLP, vendor (Portkey/LangSmith)
          and DynamoDB endpoints. Mirrors the Helm NetworkPolicy; deploy/ecs/terraform/main.tf
          (lines 105-123) documents tightening via VPC interface endpoints + NAT in production.
          A reusable module cannot pin caller-specific CIDRs.
        created: 2026-06-28T00:00:00.000Z
  # ─── Third-party Terraform module CACHE (.terraform/, gitignored init download) ──────────────
  # These are the UPSTREAM modules' own source/examples, not first-party config. Scoped to the
  # exact .terraform resource paths so the same rule firing on first-party .tf still surfaces.
  SNYK-CC-TF-125: # DynamoDB PITR — our own table sets point_in_time_recovery_enabled = true (main.tf:50)
    - 'deploy/ecs/terraform/.terraform/modules/table/main.tf > resource > aws_dynamodb_table[this] > point_in_time_recovery > enabled':
        reason: Third-party terraform-aws-modules/dynamodb-table cache; our usage enables PITR.
        created: 2026-06-28T00:00:00.000Z
    - 'deploy/ecs/terraform/.terraform/modules/table/main.tf > resource > aws_dynamodb_table[autoscaled] > point_in_time_recovery > enabled':
        reason: Third-party terraform-aws-modules/dynamodb-table cache; our usage enables PITR.
        created: 2026-06-28T00:00:00.000Z
    - 'deploy/ecs/terraform/.terraform/modules/table/main.tf > resource > aws_dynamodb_table[autoscaled_gsi_ignore] > point_in_time_recovery > enabled':
        reason: Third-party terraform-aws-modules/dynamodb-table cache; our usage enables PITR.
        created: 2026-06-28T00:00:00.000Z
  SNYK-CC-TF-128: # ECS ContainerInsights — third-party ecs/aws cluster sub-module default
    - 'deploy/ecs/terraform/.terraform/modules/cluster/modules/cluster/main.tf > resource > aws_ecs_cluster[this] > setting':
        reason: Third-party terraform-aws-modules/ecs cache (cluster sub-module).
        created: 2026-06-28T00:00:00.000Z
    - 'deploy/ecs/terraform/.terraform/modules/service/modules/cluster/main.tf > resource > aws_ecs_cluster[this] > setting':
        reason: Third-party terraform-aws-modules/ecs cache (service→cluster sub-module).
        created: 2026-06-28T00:00:00.000Z
  SNYK-CC-TF-72: # open egress — third-party security-group module's computed rules
    - 'deploy/ecs/terraform/.terraform/modules/sg/main.tf > resource > aws_security_group_rule[computed_egress_rules]':
        reason: Third-party terraform-aws-modules/security-group cache; not used by our SG (we use a raw resource).
        created: 2026-06-28T00:00:00.000Z
    - 'deploy/ecs/terraform/.terraform/modules/sg/main.tf > resource > aws_security_group_rule[egress_rules]':
        reason: Third-party terraform-aws-modules/security-group cache; not used by our SG (we use a raw resource).
        created: 2026-06-28T00:00:00.000Z
  SNYK-CC-TF-14: # KMS key rotation — third-party module's global-tables EXAMPLE
    - 'deploy/ecs/terraform/.terraform/modules/table/examples/global-tables/main.tf > input > resource > aws_kms_key[primary] > enable_key_rotation':
        reason: Third-party module example file (.terraform cache); not deployed by this module.
        created: 2026-06-28T00:00:00.000Z
    - 'deploy/ecs/terraform/.terraform/modules/table/examples/global-tables/main.tf > input > resource > aws_kms_key[secondary] > enable_key_rotation':
        reason: Third-party module example file (.terraform cache); not deployed by this module.
        created: 2026-06-28T00:00:00.000Z
patch: {}
